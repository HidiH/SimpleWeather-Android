<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget"
    style="@style/Widget.AppWidget.AppWidget.Container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:theme="@style/AppWidgetTheme.AppWidgetContainer"
    tools:ignore="ContentDescription,UnusedAttribute,UseAppTint,HardcodedText"
    tools:layout_height="wrap_content"
    tools:layout_width="192dp"
    tools:viewBindingIgnore="true">

    <TextView
        android:id="@+id/location_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingVertical="2dp"
        android:paddingHorizontal="4dp"
        android:textColor="@color/widget_m3_pill_foreground_color"
        android:textSize="14sp"
        android:textStyle="bold"
        android:text="London" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="8dp"
        android:layout_gravity="center" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/weather_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:tint="@color/widget_m3_pill_foreground_color"
            android:tintMode="src_in"
            android:layout_alignParentStart="true"
            android:src="@drawable/wi_day_sunny" />

        <TextView
            android:id="@+id/condition_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_toEndOf="@id/weather_icon"
            android:layout_alignTop="@id/weather_icon"
            android:layout_alignBottom="@id/weather_icon"
            android:layout_marginStart="4dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:includeFontPadding="false"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="@color/widget_m3_pill_foreground_color"
            android:textFontWeight="500"
            android:textSize="48sp"
            android:text="14°"
            android:autoSizeTextType="uniform"
            android:autoSizeMaxTextSize="48sp" />

        <TextView
            android:id="@+id/condition_feelslike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_below="@id/weather_icon"
            android:gravity="center_vertical"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingVertical="4dp"
            android:paddingHorizontal="4dp"
            android:textFontWeight="500"
            android:textColor="@color/widget_m3_pill_foreground_color"
            android:textSize="18sp"
            android:text="Feels like 13°" />

        <TextView
            android:id="@+id/condition_hi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_below="@id/condition_feelslike"
            android:minWidth="36dp"
            android:textColor="@color/widget_m3_pill_foreground_color"
            android:textSize="18sp"
            android:text="16°" />

        <TextView
            android:id="@+id/condition_spacer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_toEndOf="@id/condition_hi"
            android:layout_below="@id/condition_feelslike"
            android:text="\u2022"
            android:textColor="@color/widget_m3_pill_foreground_color"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/condition_lo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/condition_spacer"
            android:layout_below="@id/condition_feelslike"
            android:alpha="0.5"
            android:gravity="center_horizontal"
            android:minWidth="36dp"
            android:textColor="?colorOnSurface"
            android:textSize="18sp"
            android:text="11°" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/hrforecast_layout"
        style="@style/Widget.AppWidget.AppWidget.InnerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="gone" />

    <LinearLayout
        android:id="@+id/forecast_layout"
        style="@style/Widget.AppWidget.AppWidget.InnerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:background="@null"
        android:padding="0dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="gone" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="8dp"
        android:layout_gravity="center" />

</LinearLayout>