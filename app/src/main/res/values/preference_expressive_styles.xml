        <item name="android:layout">@layout/preference_widget_buttongroup_expressive</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.ProviderIconPreference.Expressive" parent="Preference.ProviderIconPreference">
        <item name="android:layout">@layout/preference_providericon_expressive</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.RadioButtonPreference.Expressive" parent="Preference.RadioButtonPreference">
        <item name="android:layout">@layout/preference_radio_expressive</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.IconProviderPreference.Expressive" parent="Preference.IconProviderPreference">
        <item name="android:layout">@layout/preference_icon_expressive</item>
        <item name="iconSpaceReserved">false</item>
