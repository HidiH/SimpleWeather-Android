    <style name="Preference.MaterialSwitchCompat.Expressive" parent="Preference.MaterialSwitchCompat">
        <item name="android:layout">@layout/preference_material_expressive</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.MaterialSwitch.Expressive" parent="Preference.MaterialSwitch">
        <item name="android:layout">@layout/preference_material_expressive</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.ChipPreference.Expressive" parent="Preference.ChipPreference">
        <item name="android:layout">@layout/preference_widget_chip_expressive</item>
        <item name="iconSpaceReserved">false</item>
