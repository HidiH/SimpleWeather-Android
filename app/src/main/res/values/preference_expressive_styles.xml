    <style name="Preference.PreferenceScreen.Material.Expressive" parent="Preference.PreferenceScreen.Material">
        <item name="android:layout">@layout/preference_material_expressive</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.SliderPreference.Material.Expressive" parent="Preference.SliderPreference.Material">
        <item name="android:layout">@layout/preference_widget_slider_material_expressive</item>
        <item name="iconSpaceReserved">false</item>
