<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Preference.SliderPreference">
        <item name="android:layout">@layout/preference_widget_slider</item>
        <item name="adjustable">true</item>
        <item name="showSeekBarValue">true</item>
        <item name="updatesContinuously">false</item>
    </style>

    <style name="Preference.SliderPreference.Material">
        <item name="android:layout">@layout/preference_widget_slider_material</item>
        <item name="adjustable">true</item>
        <item name="showSeekBarValue">false</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">true</item>
        <item name="iconSpaceReserved">@bool/config_materialPreferenceIconSpaceReserved</item>
    </style>
</resources>