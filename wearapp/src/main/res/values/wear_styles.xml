<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.Wear.WearChipButton" parent="@android:style/Widget">
        <item name="android:enabled">true</item>
        <item name="android:clickable">true</item>
        <item name="android:foreground">@drawable/round_selectable_item</item>
        <item name="android:checkable">false</item>
        <item name="android:background">@drawable/button_background_solid</item>
        <item name="backgroundTint">@color/button_background</item>
        <!--<item name="android:minWidth">172dp</item>-->
        <item name="minHeight">52dp</item>
        <item name="primaryTextAppearance">@style/TextAppearance.WearChipButton.PrimaryText</item>
        <item name="secondaryTextAppearance">@style/TextAppearance.WearChipButton.SecondaryText
        </item>
    </style>

    <style name="TextAppearance.WearChipButton.PrimaryText" parent="TextAppearance.Roboto.LabelMedium">
        <item name="android:textColor">@color/wear_chip_primary_text_color</item>
    </style>

    <style name="TextAppearance.WearChipButton.SecondaryText" parent="TextAppearance.Roboto.LabelSmall">
        <item name="android:textColor">@color/wear_chip_secondary_text_color</item>
    </style>

    <style name="TextAppearance.WearChipButton.Tonal.PrimaryText" parent="TextAppearance.WearChipButton.PrimaryText">
        <item name="android:textColor">@color/wear_chip_tonal_primary_text_color</item>
    </style>

    <style name="TextAppearance.WearChipButton.Tonal.SecondaryText" parent="TextAppearance.WearChipButton.SecondaryText">
        <item name="android:textColor">@color/wear_chip_tonal_secondary_text_color</item>
    </style>

    <style name="Widget.Wear.WearChipButton.Tonal" parent="Widget.Wear.WearChipButton">
        <item name="backgroundTint">?colorPrimaryContainer</item>
        <item name="primaryTextAppearance">@style/TextAppearance.WearChipButton.Tonal.PrimaryText
        </item>
        <item name="secondaryTextAppearance">
            @style/TextAppearance.WearChipButton.Tonal.SecondaryText
        </item>
    </style>

    <style name="Widget.Wear.WearChipButton.Checkable" parent="Widget.Wear.WearChipButton">
        <item name="android:checkable">true</item>
        <item name="backgroundTint">@color/button_background_checkable</item>
    </style>

</resources>